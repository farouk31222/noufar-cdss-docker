# Copy this file to .env and fill in your values
# NEVER commit the .env file to GitHub

PORT=5000
FLASK_AI_URL=http://ai-server:5001
MONGODB_URI=mongodb://mongo:27017/noufar_cdss
NODE_ENV=production
ALLOW_DEV_EMPTY_ADMIN_BOOTSTRAP=false
APP_BASE_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Change these to strong secret values!
JWT_SECRET=change_me_to_a_strong_secret
JWT_REFRESH_SECRET=change_me_to_a_second_strong_secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_REGISTRATION_KEY=change_me_to_a_strong_key

# Patient data encryption (required in production-like mode)
# Generate 32-byte keys (hex or base64). Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PATIENT_DATA_ACTIVE_KEY_ID=v1
PATIENT_DATA_KEYS={"v1":"replace_with_64_hex_chars_key_v1","v2":"replace_with_64_hex_chars_key_v2"}
PATIENT_BLIND_INDEX_KEY=replace_with_64_hex_chars_blind_index_key

# Production-like startup now validates these values strictly.
# In production/internal-clinical mode:
# - JWT_SECRET and JWT_REFRESH_SECRET must be different
# - placeholder/demo values are rejected
# - ALLOW_DEV_EMPTY_ADMIN_BOOTSTRAP must stay false

# One-time admin seed command configuration
# Use only with: npm run seed:admin
SEED_ADMIN_NAME=Clinical Platform Administrator
SEED_ADMIN_EMAIL=admin@example-clinic.com
SEED_ADMIN_PASSWORD=ChangeThisAdminPassword!2026

# Your Gmail credentials for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="NOUFAR CDSS <your_email@gmail.com>"

# Optional object storage with MinIO
# If MinIO is enabled in production-like mode, weak defaults such as
# MINIO_ACCESS_KEY=minioadmin and MINIO_SECRET_KEY=minioadmin are rejected.
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=noufar-private-files

# Upload scanning hook (prepared for future antivirus integration)
UPLOAD_MALWARE_SCAN_MODE=disabled

# Rate limiting
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_2FA_WINDOW_MS=600000
RATE_LIMIT_2FA_MAX=5
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=1800000
RATE_LIMIT_FORGOT_PASSWORD_MAX=5
RATE_LIMIT_RESET_PASSWORD_WINDOW_MS=1800000
RATE_LIMIT_RESET_PASSWORD_MAX=5
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_CREATE_ADMIN_WINDOW_MS=3600000
RATE_LIMIT_CREATE_ADMIN_MAX=4
RATE_LIMIT_SUPPORT_CREATE_WINDOW_MS=900000
RATE_LIMIT_SUPPORT_CREATE_MAX=5
RATE_LIMIT_SUPPORT_REPLY_WINDOW_MS=300000
RATE_LIMIT_SUPPORT_REPLY_MAX=12
RATE_LIMIT_PREDICTION_CREATE_WINDOW_MS=600000
RATE_LIMIT_PREDICTION_CREATE_MAX=12
RATE_LIMIT_PREDICTION_UPDATE_WINDOW_MS=600000
RATE_LIMIT_PREDICTION_UPDATE_MAX=12

# Account-level auth protection
AUTH_LOGIN_LOCK_THRESHOLD=5
AUTH_2FA_LOCK_THRESHOLD=5
AUTH_LOCK_BASE_MS=900000
AUTH_LOCK_MAX_MS=86400000
